{
  "name": "tokencraft-neo",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first design token editor, launched via npx",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @tokencraft/web dev",
    "dev:docs": "pnpm --filter @tokencraft/docs dev",
    "build": "pnpm --filter @tokencraft/web build",
    "build:docs": "pnpm --filter @tokencraft/docs build",
    "build:cli": "pnpm --filter tokencraft build",
    "lint": "pnpm --filter @tokencraft/web lint",
    "test": "pnpm --filter @tokencraft/web test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
