generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BillingPlan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum BillingStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum WorkspaceScope {
  USER
  ORGANIZATION
}

enum WorkspaceConnectionStatus {
  NOT_CONNECTED
  INSTALLATION_CONNECTED
  REPOSITORY_SELECTED
  SCAN_PENDING
}

enum GitHubAccountType {
  USER
  ORGANIZATION
}

enum TokenFileSyncStatus {
  SYNCED
  LOCAL
}

enum TokenFileFormat {
  DTCG
  TOKENS_STUDIO
  STYLE_DICTIONARY
  CUSTOM
}

enum TokenScanStatus {
  RUNNING
  SUCCESS
  FAILED
}

model Workspace {
  id               String                    @id @default(cuid())
  name             String
  slug             String
  scope            WorkspaceScope
  ownerId          String
  connectionStatus WorkspaceConnectionStatus @default(NOT_CONNECTED)
  selectedRepositoryId String?
  activeBranch         String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  selectedRepository GitHubRepository? @relation("WorkspaceSelectedRepository", fields: [selectedRepositoryId], references: [id], onDelete: SetNull)
  tokenFiles TokenFile[]
  tokenScans TokenScan[]

  @@unique([scope, ownerId, slug])
  @@index([ownerId])
  @@index([selectedRepositoryId])
}

model GitHubInstallation {
  id             String            @id @default(cuid())
  installationId BigInt            @unique
  accountLogin   String
  accountType    GitHubAccountType
  repositoryIds  BigInt[]
  scope          WorkspaceScope
  ownerId        String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  repositories GitHubRepository[]

  @@unique([scope, ownerId])
  @@index([ownerId])
  @@index([accountLogin])
}

model GitHubRepository {
  id             String             @id @default(cuid())
  repositoryId   BigInt             @unique
  installationId String
  owner          String
  name           String
  fullName       String
  defaultBranch  String
  private        Boolean
  htmlUrl        String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  installation GitHubInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  selectedByWorkspaces Workspace[] @relation("WorkspaceSelectedRepository")
  tokenFiles TokenFile[]
  tokenScans TokenScan[]

  @@index([installationId])
  @@index([fullName])
}

model TokenFile {
  id             String              @id @default(cuid())
  workspaceId    String
  repositoryId   String
  path           String
  sha            String?
  syncStatus     TokenFileSyncStatus @default(SYNCED)
  pendingDelete  Boolean             @default(false)
  collectionName String
  format         TokenFileFormat
  tokenCount     Int
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository GitHubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, path])
  @@index([repositoryId])
}

model TokenScan {
  id                String          @id @default(cuid())
  workspaceId       String
  repositoryId      String
  status            TokenScanStatus @default(RUNNING)
  scannedFileCount  Int             @default(0)
  tokenFileCount    Int             @default(0)
  message           String?
  startedAt         DateTime        @default(now())
  completedAt       DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository GitHubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([repositoryId])
  @@index([status])
}

model Subscription {
  id                   String        @id @default(cuid())
  scope                WorkspaceScope
  ownerId              String
  plan                 BillingPlan   @default(FREE)
  status               BillingStatus @default(INCOMPLETE)
  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?       @unique
  currentPeriodEnd     DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@unique([scope, ownerId])
  @@index([ownerId])
}
